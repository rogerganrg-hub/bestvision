{
  "name": "bestvision",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "pnpm --filter @bestvision/api dev",
    "dev:web": "pnpm --filter @bestvision/web dev",
    "dev": "pnpm dev:api && pnpm dev:web",
    "build:api": "pnpm -C apps/api run build",
    "typecheck:api": "pnpm -C apps/api exec tsc -p tsconfig.json",
    "typecheck:web": "pnpm -C apps/web exec tsc -p tsconfig.json",
    "typecheck": "pnpm run typecheck:api && pnpm run typecheck:web"
  },
  "author": "BestVisionPlatform/RogerGan",
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "engines": {
    "node": ">=18.0.0"
  }
}
