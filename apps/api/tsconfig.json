{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "noEmitOnError": true
  },
  "include": [
    "server.ts",
    "routes/**/*.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "scripts"
  ],
  "exclude": ["node_modules", "dist", "data", "coverage"]
}
